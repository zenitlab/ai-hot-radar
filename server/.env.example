# 数据库
DATABASE_URL="file:./dev.db"

# 服务器配置
PORT=3001
CLIENT_URL=http://localhost:5173

# AI 模型配置 (兼容 OpenAI 格式)
# 支持: 阿里云百炼 / 硅基流动 / DeepSeek / OpenAI 等
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-coder-turbo

# AI 调用速率控制（应对不同提供商的 RPM 限制）
# AI_MAX_CONCURRENT: 全局并发上限（默认 5；MiMo/小厂建议 3，DashScope/SF 可调到 10）
# AI_MAX_RETRIES_429: 遇到 429 时的指数退避重试次数（默认 3）
# AI_MAX_TOKENS: 单次调用 max_tokens（默认 1500；推理类模型 MiMo/R1 建议 2500-3000）
AI_MAX_CONCURRENT=5
AI_MAX_RETRIES_429=3
AI_MAX_TOKENS=1500

# 备选: 硅基流动
# OPENAI_API_KEY=your_siliconflow_api_key_here
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# MODEL_NAME=Qwen3-30B-A3B-Instruct-2507

# 备选: 小米 MiMo（速率限制较严格，建议把 AI_MAX_CONCURRENT 调到 3）
# OPENAI_API_KEY=your_mimo_api_key_here
# OPENAI_BASE_URL=https://...
# MODEL_NAME=mimo-...

# Twitter API (twitterapi.io)
TWITTER_API_KEY=your_twitter_api_key_here

# 邮件通知 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password
NOTIFY_EMAIL=notify_to@example.com
