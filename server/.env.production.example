# =====================================================================
# Production env template for AI Hot Radar (server)
#
# On the server:
#   cp .env.production.example .env.production
#   vim .env.production   # fill in real values
#
# .env.production is gitignored; this template is committed.
# =====================================================================

# ---- Database (SQLite, mounted via docker volume ./data) ----
# Path is INSIDE the container; ./data on the host is mounted to /app/data.
DATABASE_URL="file:/app/data/dev.db"

# ---- Server ----
PORT=3001
# Public origin used for CORS / generated links. Replace with your domain.
CLIENT_URL=https://aihotradar.com

# ---- AI provider (OpenAI-compatible) ----
# Pick ONE upstream and fill its key + base URL.
#
# Aliyun DashScope (Qwen):
OPENAI_API_KEY=replace_me
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-coder-turbo
#
# SiliconFlow:
# OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# MODEL_NAME=Qwen3-30B-A3B-Instruct-2507
#
# DeepSeek:
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# MODEL_NAME=deepseek-chat

# ---- AI rate-limit knobs ----
# AI_MAX_CONCURRENT: global concurrency cap (default 5; lower for strict providers)
# AI_MAX_RETRIES_429: exponential backoff retries on HTTP 429
# AI_MAX_TOKENS: max_tokens per call (raise to 2500-3000 for reasoning models)
AI_MAX_CONCURRENT=5
AI_MAX_RETRIES_429=3
AI_MAX_TOKENS=1500

# ---- Twitter (twitterapi.io). Leave blank to disable that source. ----
TWITTER_API_KEY=

# ---- SMTP (optional, for keyword-hit notifications) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
