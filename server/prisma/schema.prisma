// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Keyword {
  id         String      @id @default(uuid())
  text       String      @unique
  category   String?
  isActive   Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  hotspots   Hotspot[]
  entityCard EntityCard?
}

model EntityCard {
  id          String   @id @default(uuid())
  keywordId   String   @unique
  keyword     Keyword  @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  name        String
  type        String?  // model|company|product|technology|person
  summary     String?
  relatedData String?  // JSON: {relatedCompanies, relatedModels, relatedProducts, competesWith, aliases, tags}
  lastRefresh DateTime @default(now())
  createdAt   DateTime @default(now())
}

model EntityRelation {
  id       String @id @default(uuid())
  fromName String
  toName   String
  relation String // made_by|integrates|competes|related_to
  @@unique([fromName, toName])
}

model Hotspot {
  id              String    @id @default(uuid())
  title           String
  content         String
  url             String
  source          String    // twitter, bing, google
  sourceId        String?   // 原始推文ID等
  isReal          Boolean   @default(true)
  relevance       Int       @default(0)
  relevanceReason String?   // AI 分析相关性的理由
  keywordMentioned Boolean?  // 内容中是否直接提及了关键词
  importance      String    @default("low")
  summary         String?
  viewCount       Int?
  likeCount       Int?
  retweetCount    Int?
  replyCount      Int?      // 回复数
  commentCount    Int?      // 评论数
  quoteCount      Int?      // 引用/转引数
  danmakuCount    Int?      // 弹幕数 (Bilibili)
  authorName      String?   // 作者名称
  authorUsername  String?   // 作者用户名
  authorAvatar    String?   // 作者头像
  authorFollowers Int?      // 作者粉丝数
  authorVerified  Boolean?  // 作者是否认证
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  keywordId       String?
  keyword         Keyword?  @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  category       String?   // model|product|industry|research|community|tips
  region         String?   // domestic|international
  sourceTier     String?   // T1|T1.5|T2
  qualityScore   Float?    // 0-100 composite quality score (code-computed)
  isCurated      Boolean   @default(false)
  tags           String?   // JSON array string e.g. ["tag1","tag2"]
  clusterKey     String?   // event clustering key (title hash)
  isClusterMain  Boolean   @default(true)
  biliCategory   String?   // Bilibili category name
  biliTags       String?   // Bilibili tags (comma-separated)
  favoritesCount Int?      // Bilibili favorites count

  @@unique([url, source])
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // hotspot, alert
  title     String
  content   String
  isRead    Boolean  @default(false)
  hotspotId String?
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

model ChatSession {
  id        String        @id @default(uuid())
  title     String?
  createdAt DateTime      @default(now())
  messages  ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String      // user | assistant
  content   String
  createdAt DateTime    @default(now())
}

model DailyDigest {
  id        String   @id @default(uuid())
  date      String   @unique  // YYYY-MM-DD (Beijing time)
  data      String   // JSON string with categorized digest
  createdAt DateTime @default(now())
}
